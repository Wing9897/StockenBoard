{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Vitest globals (describe/it/expect) + jest-dom matcher types.
    // Kept out of the main build config so production type-checking
    // (npm run build) stays free of test-only types.
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "exclude": [],
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/test"
  ]
}
