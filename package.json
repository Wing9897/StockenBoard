{
  "name": "stockenboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "StockenBoard - Stock & Token Dashboard",
  "author": "Wing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wing9897/stockenboard.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "server:dev": "node scripts/build-server.mjs --dev --run",
    "server:build": "node scripts/build-server.mjs",
    "server:run": "node scripts/build-server.mjs --run",
    "server:build:linux-x64": "node scripts/build-server.mjs --target x86_64-unknown-linux-gnu",
    "server:build:mac-arm64": "node scripts/build-server.mjs --target aarch64-apple-darwin",
    "server:build:win-x64": "node scripts/build-server.mjs --target x86_64-pc-windows-msvc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cd src-tauri && cargo test --no-default-features --features server",
    "test:all": "npm test && npm run test:rust",
    "version:bump": "node scripts/bump-version.mjs",
    "docker:build": "docker build -t stockenboard .",
    "docker:run": "docker run -d -p 8080:8080 -v stockenboard-data:/data stockenboard",
    "check:i18n": "node scripts/check-i18n.js",
    "lint": "tsc --noEmit && node scripts/check-i18n.js && cd src-tauri && cargo clippy --no-default-features --features server -- -D warnings"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lightweight-charts": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  }
}
